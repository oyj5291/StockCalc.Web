@model TargetPriceCalculatorViewModel
@{
    ViewData["Title"] = "목표가 계산기";
}

<section class="page-title"><p class="eyebrow">Calculator</p><h1>목표가 계산기</h1><p>원하는 수익률에 도달하기 위한 목표 매도가를 계산합니다.</p></section>
<section class="calculator">
    <form asp-action="TargetPrice" method="post">
        <div class="form-grid">
            <div class="field"><label asp-for="BuyPrice"></label><input asp-for="BuyPrice" type="number" step="1" /></div>
            <div class="field"><label asp-for="TargetRate"></label><input asp-for="TargetRate" type="number" step="0.1" /></div>
        </div>
        <div class="form-actions"><button class="button primary" type="submit">계산하기</button><a class="button" asp-action="TargetPrice">초기화</a></div>
    </form>
    <div class="results">
        <div class="result-row"><span>목표 매도가</span><strong>@Model.TargetPrice.ToString("N0")원</strong></div>
        <div class="result-row"><span>1주당 예상 수익</span><strong>@Model.ProfitPerShare.ToString("N0")원</strong></div>
    </div>
</section>
<aside class="ad-box">광고 영역</aside>
<section class="content"><div class="notice">목표가는 계산상 기준일 뿐이며 실제 시장 가격을 보장하지 않습니다.</div><h2>목표가 활용법</h2><p>목표 수익률을 가격으로 바꾸면 익절 기준을 더 명확히 세울 수 있습니다.</p></section>
