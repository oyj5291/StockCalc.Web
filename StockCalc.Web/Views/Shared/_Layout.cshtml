<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["Description"] ?? "주식 수익률, 평단가, 물타기, 손절가, 목표가, 배당금, 복리 수익률을 계산하는 정보성 투자 계산기 사이트입니다.")" />
    <title>@ViewData["Title"] | 주식계산연구소</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <a class="brand" asp-controller="Home" asp-action="Index">주식계산연구소</a>
        <button class="nav-toggle" type="button" aria-label="메뉴 열기" aria-expanded="false">☰</button>
        <nav class="site-nav" aria-label="주요 메뉴">
            <a asp-controller="Home" asp-action="Index">홈</a>
            <details class="nav-menu">
                <summary>주식계산기</summary>
                <div class="nav-dropdown">
                    <a asp-controller="Calculators" asp-action="Profit">수익률 계산기</a>
                    <a asp-controller="Calculators" asp-action="AveragePrice">평단가 계산기</a>
                    <a asp-controller="Calculators" asp-action="WaterAverage">물타기 계산기</a>
                    <a asp-controller="Calculators" asp-action="StopLoss">손절가 계산기</a>
                    <a asp-controller="Calculators" asp-action="TargetPrice">목표가 계산기</a>
                    <a asp-controller="Calculators" asp-action="Dividend">배당금 계산기</a>
                    <a asp-controller="Calculators" asp-action="Compound">복리 계산기</a>
                </div>
            </details>
            <details class="nav-menu">
                <summary>투자기초</summary>
                <div class="nav-dropdown">
                    <a asp-controller="Articles" asp-action="AveragePriceGuide">평단가란?</a>
                    <a asp-controller="Calculators" asp-action="StopLoss">손절가란?</a>
                    <a asp-controller="Calculators" asp-action="Dividend">배당수익률이란?</a>
                    <a asp-controller="Articles" asp-action="BasicStockReturn">수익률 계산 방법</a>
                    <a asp-controller="Articles" asp-action="SamsungTenPercentProfit">삼성전자 10% 수익 계산</a>
                    <a asp-controller="Articles" asp-action="SplitBuyCalculatorGuide">분할매수 계산기 사용법</a>
                    <a asp-controller="Articles" asp-action="StopLossCalculationGuide">손절가 계산 방법</a>
                    <a asp-controller="Articles" asp-action="TargetReturnCalculation">목표수익률 계산법</a>
                    <a asp-controller="Articles" asp-action="AfterTaxDividendCalculation">배당금 세후 계산</a>
                    <a asp-controller="Articles" asp-action="StockTaxBasics">주식 세금 기초</a>
                    <a asp-controller="Articles" asp-action="EtfLongTermReturn">ETF 장기수익률</a>
                    <a asp-controller="Articles" asp-action="AveragingDownCostBasis">물타기 후 평단가</a>
                </div>
            </details>
            <details class="nav-menu">
                <summary>백테스트 연구</summary>
                <div class="nav-dropdown nav-dropdown-right">
                    <a asp-controller="Articles" asp-action="StockBacktestGuide">백테스트란?</a>
                    <a asp-controller="Articles" asp-action="StockBacktestGuide" asp-fragment="example">10% 익절/손절 전략</a>
                    <a asp-controller="Articles" asp-action="SplitBuyCalculatorGuide">분할매수 전략</a>
                    <a asp-controller="Articles" asp-action="StockBacktestGuide" asp-fragment="example">이동평균선 전략</a>
                </div>
            </details>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <strong>주식계산연구소</strong>
        <p>본 사이트는 계산 편의를 위한 정보성 도구이며, 특정 종목 추천이나 투자 권유를 제공하지 않습니다.</p>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
