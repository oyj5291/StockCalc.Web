[Unit]
Description=StockCalc Web
After=network.target

[Service]
WorkingDirectory=/var/www/stockcalc-web
ExecStart=/usr/bin/dotnet /var/www/stockcalc-web/StockCalc.Web.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=stockcalc-web
User=www-data
Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://127.0.0.1:5000

[Install]
WantedBy=multi-user.target
